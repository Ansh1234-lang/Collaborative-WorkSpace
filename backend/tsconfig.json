{
    "compilerOptions": {
        "target": "es2025",
        "module": "commonjs",
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["node"]
    },
    "exclude": ["prisma.config.ts", "node_modules"]
}